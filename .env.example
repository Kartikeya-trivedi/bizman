# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from your Supabase dashboard (Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key (safe for client-side calls)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (NEVER expose to client — server-side only, bypasses RLS)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── Google AI / Gemini ───────────────────────────────────────────────────────
# API key from Google AI Studio (aistudio.google.com)
# Used by Agno's Gemini model provider for LLM calls (not embeddings)
GOOGLE_API_KEY=your_google_api_key_here

# LLM model name for Agno Agent (default shown)
GEMINI_MODEL=gemini-2.0-flash

# ─── Embeddings (Local HuggingFace) ──────────────────────────────────────────
# SentenceTransformer model from HuggingFace (downloaded automatically)
# Good options: all-MiniLM-L6-v2 (fast, 384d), all-mpnet-base-v2 (better, 768d)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL. Docker Compose uses "redis://redis:6379"
# Local dev: "redis://localhost:6379"
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds (default: 1 hour)
REDIS_CACHE_TTL=3600

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# ─── RAG Settings ─────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.35

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Set this in frontend/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
